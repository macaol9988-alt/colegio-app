# ============================================================
# CONFIGURACAO DO SISTEMA DO COLEGIO
# ============================================================
# Copie este arquivo como .env e ajuste para o ambiente.
# Na Hostinger, voce define essas variaveis no painel Node.js
# (hPanel > Website > Avancado > Node.js > Variaveis de ambiente)
# - NAO precisa subir o arquivo .env para o servidor.
# ============================================================

# Ambiente: development (local) | production (Hostinger)
NODE_ENV=development

# Porta da aplicacao
#   - Local: pode usar 3000
#   - Hostinger: deixe vazio, a plataforma define automaticamente
PORT=3000

# URL publica do sistema (usada em links de ativacao e reset de senha)
#   - Local: http://localhost:3000
#   - Producao: https://seudominio.com  (sem barra no final)
APP_URL=http://localhost:3000

# ----------- Banco de dados MySQL -----------
# Hostinger compartilhada:
#   DB_HOST normalmente eh "localhost"
#   DB_NAME, DB_USER comecam com o prefixo da sua conta, ex: u123456_colegio
DB_HOST=localhost
DB_PORT=3306
DB_NAME=colegio
DB_USER=root
DB_PASSWORD=

# Se voce ja importou database/install.sql via phpMyAdmin (recomendado),
# o sistema NAO precisa tentar criar tabelas em runtime. Ative isso em
# hospedagem compartilhada onde o usuario do banco nao tem CREATE TABLE:
SKIP_DB_SCHEMA=false
SKIP_DB_SEED=false

# ----------- Seguranca -----------
# Gere uma string longa aleatoria. Pode usar:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-este-segredo-por-uma-string-aleatoria-bem-longa
JWT_EXPIRES_IN=12h

# ----------- E-mail (SMTP) - opcional -----------
# Sem SMTP o sistema funciona: os links de ativacao e reset aparecem
# para o admin copiar manualmente. Para automatizar, configure abaixo.
#
# Hostinger: crie uma conta de e-mail (ex: noreply@seudominio.com) e use:
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@seudominio.com
SMTP_PASSWORD=
SMTP_FROM_NAME=Colegio
SMTP_FROM_EMAIL=noreply@seudominio.com

# ----------- Admin seed (opcional) -----------
# Se o admin nao existir no banco quando o sistema subir, ele cria
# automaticamente com estes dados. Se voce importou database/install.sql
# o admin ja foi criado (admin@colegio.com / admin123) e estas variaveis
# nao serao usadas.
SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@colegio.com
SEED_ADMIN_CPF=
SEED_ADMIN_PASSWORD=admin123
